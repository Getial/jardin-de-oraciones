# ── Django ──
DJANGO_SECRET_KEY=cambia-esto-en-produccion
DEBUG=True
# Solo en producción (DEBUG=False). Railway agrega su dominio automáticamente.
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Supabase PostgreSQL (Session mode: puerto 5432) ──
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase JWT / API ──
SUPABASE_JWT_SECRET=tu-jwt-secret
SUPABASE_URL=https://tu-proyecto.supabase.co

# ── CORS — orígenes del frontend (solo en producción) ──
CORS_ALLOWED_ORIGINS=https://tu-app.vercel.app

# ── CSRF — orígenes confiables para el admin sobre HTTPS (opcional) ──
# El dominio de Railway se agrega solo; añade aquí otros si hace falta.
CSRF_TRUSTED_ORIGINS=https://tu-app.vercel.app
