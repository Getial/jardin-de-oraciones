DJANGO_SECRET_KEY=cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase PostgreSQL (Session mode: puerto 5432)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase JWT Secret (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=tu-jwt-secret
SUPABASE_URL=https://tu-proyecto.supabase.co

# CORS — URLs del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app
